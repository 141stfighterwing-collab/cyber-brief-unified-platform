# ─── Cyber Brief Unified Platform — Development Dockerfile ───
# Used with: docker compose -f docker-compose.dev.yml up
# Includes full dev toolchain and hot-reload support

FROM node:20-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends openssl unzip curl git ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install Bun
RUN npm install -g bun@1.2.2 || npm install -g bun

WORKDIR /app

# Copy dependency files
COPY package.json bun.lock ./

# Install all dependencies (including devDependencies)
RUN bun install

# Copy source
COPY . .

# Generate Prisma client
RUN bunx prisma generate

# Initialize database
ENV DATABASE_URL="file:/app/data/cbup.db"
RUN mkdir -p /app/data && bunx prisma db push --skip-generate 2>/dev/null || true

EXPOSE 3000

ENV NODE_ENV=development
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["bun", "run", "dev"]

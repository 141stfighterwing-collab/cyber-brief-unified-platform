generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid()) @db.VarChar(30)
  email     String   @unique @db.VarChar(255)
  name      String?  @db.VarChar(255)
  company   String?  @db.VarChar(255)
  tier      String   @default("free") @db.VarChar(50)
  password  String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @db.DateTime(3)
  updatedAt DateTime @updatedAt @db.DateTime(3)
}

model Alert {
  id          String   @id @default(cuid()) @db.VarChar(30)
  title       String   @db.VarChar(500)
  severity    String   @db.VarChar(50)
  source      String   @db.VarChar(255)
  description String   @db.Text
  category    String   @db.VarChar(100)
  createdAt   DateTime @default(now()) @db.DateTime(3)
}

model Brief {
  id          String   @id @default(cuid()) @db.VarChar(30)
  title       String   @db.VarChar(500)
  volume      Int
  content     String   @db.LongText
  publishedAt DateTime @default(now()) @db.DateTime(3)
}

model Task {
  id          String    @id @default(cuid()) @db.VarChar(30)
  title       String    @db.VarChar(500)
  description String?   @db.Text
  status      String    @default("new") @db.VarChar(50)
  priority    String    @default("medium") @db.VarChar(50)
  assignee    String?   @db.VarChar(255)
  dueDate     DateTime? @db.DateTime(3)
  createdAt   DateTime  @default(now()) @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @db.DateTime(3)
}

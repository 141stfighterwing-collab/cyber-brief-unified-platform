// =============================================================================
// Cyber Brief Unified Platform – Default Schema (SQLite)
// =============================================================================
//
// For MySQL:    cp schema.mysql.prisma schema.prisma && bunx prisma generate
// For PostgreSQL: cp schema.postgresql.prisma schema.prisma && bunx prisma generate
//
// After swapping, run: prisma db push   (or prisma migrate dev)
//
// The runtime provider is selected via DATABASE_PROVIDER env var in db-provider.ts.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// MULTI-TENANCY
// =============================================================================

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  plan        String   @default("free")  // free, pro, enterprise
  maxAgents   Int      @default(10)
  settings    String?                     // JSON settings
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       TenantUser[]
  agents      Agent[]
  reports     SecurityReport[]
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserTenants", fields: [userId], references: [id])
  role      String   @default("member")  // owner, admin, analyst, member
  createdAt DateTime @default(now())

  @@unique([tenantId, userId])
}

// =============================================================================
// USER (enhanced with role for super-admin)
// =============================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  company   String?
  tier      String   @default("free")
  role      String   @default("user")     // user, admin, super_admin
  password  String?
  avatar    String?
  settings  String?                       // JSON user preferences
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants   TenantUser[] @relation("UserTenants")
}

// =============================================================================
// CORE PLATFORM
// =============================================================================

model Alert {
  id          String   @id @default(cuid())
  title       String
  severity    String
  source      String
  description String
  category    String
  agentId     String?                      // Optional link to agent
  tenantId    String?                      // Optional link to tenant
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Brief {
  id          String   @id @default(cuid())
  title       String
  volume      Int
  content     String
  publishedAt DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("new")
  priority    String    @default("medium")
  assignee    String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// =============================================================================
// ENDPOINT AGENTS
// =============================================================================

model Agent {
  id            String     @id @default(cuid())
  agentId       String     @unique              // Unique agent identifier (GUID from agent)
  tenantId      String?                         // Optional tenant assignment
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  hostname      String
  domain        String?
  osName        String
  osVersion     String
  osArch        String?
  manufacturer  String?
  model         String?
  serialNumber  String?
  biosVersion   String?
  cpuModel      String?
  cpuCores      Int?
  totalRamMb    Int?
  macAddresses  String?                         // JSON array
  ipAddresses   String?                         // JSON array
  status        String     @default("online")   // online, offline, warning, critical
  lastSeen      DateTime   @default(now())
  version       String     @default("1.0.0")    // Agent version
  authToken     String?                         // For agent authentication
  tags          String?                         // JSON array of tags
  groups        String?                         // JSON array of groups
  notes         String?                         // Admin notes
  telemetry     Telemetry[]
  commands      Command[]
  edrScans      EDRScan[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([tenantId])
}

model Telemetry {
  id           String   @id @default(cuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id])
  cpuPercent   Float?
  memPercent   Float?
  memUsedMb    Float?
  memTotalMb   Float?
  diskReadBps  Float?
  diskWriteBps Float?
  netInBps     Float?
  netOutBps    Float?
  diskFreeGb   Float?
  diskTotalGb  Float?
  activeTcp    Int?
  uptime       Int?                         // seconds
  topCpuProcs  String?                      // JSON array of top processes
  topMemProcs  String?                      // JSON array
  timestamp    DateTime @default(now())

  @@index([agentId, timestamp])
}

model Command {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
  type        String                       // RUN_EDR_SCAN, RUN_CUSTOM_SCRIPT, etc.
  payload     String?                      // JSON payload
  status      String   @default("pending") // pending, executing, completed, failed
  result      String?                      // JSON result
  error       String?
  createdBy   String?                      // User who issued the command
  createdAt   DateTime @default(now())
  executedAt  DateTime?
  completedAt DateTime?

  @@index([agentId, status])
}

model EDRScan {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
  scanType    String                       // process, service, port, autorun, vulnerability, full
  status      String   @default("running") // running, completed, failed
  findings    String                       // JSON array of findings
  summary     String?                      // JSON summary
  startedAt   DateTime @default(now())
  completedAt DateTime?
  durationMs  Int?
}

// =============================================================================
// SECURITY REPORTS
// =============================================================================

model SecurityReport {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  title       String
  type        String                       // vulnerability, compliance, edr_summary, endpoint_health, full_audit
  status      String   @default("generating") // generating, completed, failed
  data        String?                       // JSON report data
  summary     String?                       // Executive summary text
  agentIds    String?                       // JSON array of agent IDs included
  createdAt   DateTime @default(now())
  completedAt DateTime?
}
